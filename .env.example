# ==============================================================================
# 🔥 LIVE AUCTION PLATFORM PAKISTAN - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' and fill in the values before starting the server.
# ==============================================================================

# 🖥️ Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# 💾 MongoDB Configuration
# MONGODB_URI: Aapka MongoDB connection string (local ya Atlas cluster ka URL)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/vaultmaal?retryWrites=true&w=majority

# 🔑 JWT Authentication Configs
# In key values ko generate karne ke liye open terminal and type: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 🔑 ADD YOUR KEY HERE
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
# 🔑 ADD YOUR KEY HERE
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ⚡ Redis Configuration
# OTP storage and real-time bid sync rate limit/caching client
REDIS_URL=redis://127.0.0.1:6379

# ☁️ Cloudinary Configuration (For product images and videos)
# Cloudinary dashboard se credentials copy karke paste karein
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# 🔑 ADD YOUR KEY HERE
CLOUDINARY_API_KEY=your_cloudinary_api_key
# 🔑 ADD YOUR KEY HERE
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# 💬 Meta WhatsApp Cloud API Configuration
# Whatsapp alerts bejne ke liye developer.facebook.com se parameters check karein
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
# 🔑 ADD YOUR KEY HERE
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_TEMPLATE_OTP=otp_verification
WHATSAPP_TEMPLATE_REMINDER=auction_reminder
WHATSAPP_TEMPLATE_OUTBID=outbid_alert
WHATSAPP_TEMPLATE_WINNER=winner_notification
WHATSAPP_TEMPLATE_LOSER=loser_notification

# 💳 Phase 2: Payment Gateways (Leave empty for now - scaffold only)
EASYPAISA_MERCHANT_ID=
JAZZCASH_MERCHANT_ID=
